test-results/
playwright-report/
blob-report/
playwright/.cache/

# Claude Code local config (e.g. preview launch.json)
.claude/

# Design handoff bundle (not part of the app)
.design-handoff/

# Backend worker (backend/node_modules already matched by node_modules/ above)
backend/.wrangler/
